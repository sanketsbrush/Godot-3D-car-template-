[sub_resource type="GDScript" id="GDScript_b1a7y"]
resource_name = "camera_set"
script/source = "extends Node3D
@onready var fpp: Camera3D = $fpp
@onready var tpp: Camera3D = $Node/tpp
@onready var tpp_pos: Node3D = $\"tpp pos\"
@onready var tpp_look_at: Node3D = $\"tpp look at\"

func _physics_process(delta: float) -> void:
	tpp_pos.position.z=lerp(tpp_pos.position.z,Input.get_axis(\"ui_left\",\"ui_right\")*-1,.1)
	tpp.global_position=lerp(tpp.global_position,tpp_pos.global_position,.5)
	tpp.look_at(tpp_look_at.global_position,Vector3.UP,false)
	if Input.is_action_pressed(\"ui_down\"):
		rotation_degrees.y=lerp(rotation_degrees.y,270.,.1)
	else:rotation_degrees.y=lerp(rotation_degrees.y,90.,.1)
func  _process(delta: float) -> void:
	if Input.is_action_just_pressed(\"ui_focus_next\"):
		tpp.current=!tpp.current
"

