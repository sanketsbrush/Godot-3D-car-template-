[sub_resource type="GDScript" id="GDScript_mdbyd"]
script/source = "extends VehicleBody3D

@onready var fr: VehicleWheel3D = $fr
@onready var br: VehicleWheel3D = $br
@onready var fl: VehicleWheel3D = $fl
@onready var bl: VehicleWheel3D = $bl
@onready var label: Label = $Label


func _physics_process(delta: float) -> void:
	
	var vel=Input.get_axis(\"ui_down\",\"ui_up\")+.3
	var steer=Input.get_axis(\"ui_right\",\"ui_left\")
	var brk=int(Input.is_action_pressed(\"ui_accept\"))
	var lerp_drf=(abs(vel*steer)*brk)*.5
	var drf=.9-lerpf(lerp_drf,0.,0.1)
	
	engine_force=vel*500
	steering=lerpf(steering,deg_to_rad(steer*40),.2)
	bl.wheel_friction_slip=drf
	br.wheel_friction_slip=drf
	brake=brk*5

func _process(delta: float) -> void:
	var fps=Engine.get_frames_per_second()
	var spd=sqrt(linear_velocity.x**2+linear_velocity.y**2+linear_velocity.z**2)
	var drf_check=abs(int(bl.get_skidinfo())-1)
	label.text=\"fps: \"+str(fps)+\"\\nspeed: \"+str(int(spd))+\"\\nis drifting: \"+str(drf_check)

func _init() -> void:
	if Input.is_action_just_pressed(\"ui_text_delete\"):
		get_tree().reload_current_scene()

func _on_spd_2x_area_entered(area: Area3D) -> void:
	pass # Replace with function body.
func _on_spd_2x_area_exited(area: Area3D) -> void:
	pass # Replace with function body.
	
func _on_spd_3x_area_entered(area: Area3D) -> void:
	pass # Replace with function body.
func _on_spd_3x_area_exited(area: Area3D) -> void:
	pass # Replace with function body.

func _on_damp_area_entered(area: Area3D) -> void:
	pass # Replace with function body.
func _on_damp_area_exited(area: Area3D) -> void:
	pass # Replace with function body.

func _on_eng_on_off_area_entered(area: Area3D) -> void:
	pass # Replace with function body.
func _on_eng_on_off_area_exited(area: Area3D) -> void:
	pass # Replace with function body.

func _on_check_area_entered(area: Area3D) -> void:
	print(\"check\")
"

