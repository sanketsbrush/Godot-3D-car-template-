[input_devices]

pointing/android/enable_pan_and_scale_gestures=true

[layer_names]

3d_physics/layer_1="collision"
3d_physics/layer_2="fpp lock"
3d_physics/layer_3="low gravity"
3d_physics/layer_4="anti gravity"
3d_physics/layer_5="speed up"
3d_physics/layer_6="engine off"
3d_physics/layer_7="engine on"
3d_physics/layer_8="fradgile"

[physics]

common/physics_ticks_per_second=120
common/max_physics_steps_per_frame=4
3d/physics_engine="JoltPhysics3D"
common/physics_interpolation=true

[rendering]

lights_and_shadows/directional_shadow/soft_shadow_filter_quality=1
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=1
anti_aliasing/quality/screen_space_aa=2
occlusion_culling/use_occlusion_culling=true
environment/screen_space_reflection/roughness_quality=3
